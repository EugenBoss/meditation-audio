{
  "name": "meditation-audio-generator",
  "version": "1.0.0",
  "description": "Automated meditation audio generator — Puterea Minții",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "batch": "node batch-generate.js",
    "batch:ro": "node batch-generate.js --lang ro",
    "batch:en": "node batch-generate.js --lang en",
    "batch:dry": "node batch-generate.js --dry-run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "express": "^4.21.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
